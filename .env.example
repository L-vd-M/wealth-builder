# ── Frontend (set in Vercel project env for production) ──────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ── Clerk auth ────────────────────────────────────────────────────────────────
# Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Clerk Dashboard → API Keys → JWKS URL  (used by the FastAPI backend)
CLERK_JWKS_URL=https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json

# ── Database (Raspberry Pi / local) ──────────────────────────────────────────
POSTGRES_USER=mcuser
POSTGRES_PASSWORD=change_me_strong_password
# Full async URL consumed by FastAPI
DATABASE_URL=postgresql+asyncpg://mcuser:change_me_strong_password@localhost:5432/marketcommand

# ── CORS (FastAPI) ────────────────────────────────────────────────────────────
# Comma-separated origins
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# From: cloudflared tunnel token <tunnel-name>
CLOUDFLARE_TUNNEL_TOKEN=

# ── Resend email notifications (optional) ─────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com

# ── OpenAI (optional – falls back to mock) ───────────────────────────────────
OPENAI_API_KEY=

# ── Trading APIs (future) ─────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
NEWS_API_KEY=
